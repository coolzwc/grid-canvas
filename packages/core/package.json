{
  "name": "@grid-canvas/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core engine for grid-canvas: layout algorithms, pan/zoom, drag & resize",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "d3-interpolate": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coolzwc/grid-canvas.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/coolzwc/grid-canvas#readme",
  "keywords": [
    "grid",
    "layout",
    "canvas",
    "drag",
    "resize",
    "pan",
    "zoom",
    "compaction"
  ]
}
